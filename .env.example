# ===========================================
# Studánky Strapi — environment template
# ===========================================
# Copy to .env and fill in. NEVER commit .env.
#   Dev:  DATABASE_CLIENT=sqlite (default), CRON_ENABLED=false
#   Prod: docker-compose.yml sets DATABASE_CLIENT=postgres automatically
#
# Unique per host — keeps volumes/containers from clashing with other projects.
COMPOSE_PROJECT_NAME=studanky

# ===========================================
# Docker / Domain (production only)
# ===========================================
DOMAIN=studanky.example.com
ACME_EMAIL=admin@example.com

# ===========================================
# Server
# ===========================================
# Public URL for absolute links (QR deeplinks, emails). If empty it is derived
# as https://DOMAIN. Behind Traefik keep IS_PROXIED=true.
PUBLIC_URL=
HOST=0.0.0.0
PORT=1337
IS_PROXIED=true
# ČHMÚ nightly sync (03:30 Europe/Prague). Set false in local dev.
CRON_ENABLED=true
# Comma-separated allowed CORS origins in production (app + admin domains).
# Defaults to "*" — RESTRICT this in production.
CORS_ORIGINS=*

# ===========================================
# Secrets — generate each with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ===========================================
APP_KEYS=toBeGenerated1,toBeGenerated2
API_TOKEN_SALT=toBeGenerated
ADMIN_JWT_SECRET=toBeGenerated
TRANSFER_TOKEN_SALT=toBeGenerated
ENCRYPTION_KEY=toBeGenerated
JWT_SECRET=toBeGenerated
# HMAC secret for QR/report signature (min 32 chars)
HMAC_SECRET=toBeGenerated-minimum-32-characters

# ===========================================
# Database
# ===========================================
# Dev: sqlite | Prod: postgres (compose overrides DATABASE_CLIENT=postgres)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=studanky
DATABASE_USERNAME=studanky
DATABASE_PASSWORD=change-me-strong-password
DATABASE_SSL=false
# Strapi Docker recommendation: allow the DB pool to shrink to zero idle connections.
DATABASE_POOL_MIN=0
DATABASE_POOL_MAX=10

# ===========================================
# Email (SMTP) — prepared, optional
# ===========================================
# Authenticated SMTP:
#   SMTP_AUTH_ENABLED=true + SMTP_USER + SMTP_PASS
# IP-authenticated relay (e.g. Microsoft 365):
#   SMTP_AUTH_ENABLED=false and leave SMTP_USER/SMTP_PASS unset
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_AUTH_ENABLED=
SMTP_USER=
SMTP_PASS=
DEFAULT_FROM_EMAIL=noreply@example.com
DEFAULT_REPLY_TO_EMAIL=info@example.com

# ===========================================
# Object storage (S3 / Cloudflare R2) — optional
# ===========================================
# Leave AWS_BUCKET empty to keep uploads on the local volume (backed up by the
# backup container). Set AWS_BUCKET to offload media to S3/R2 (recommended once
# owners upload photos). For R2/MinIO set AWS_ENDPOINT + AWS_FORCE_PATH_STYLE=true.
AWS_BUCKET=
AWS_REGION=eu-central-1
AWS_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_ACCESS_SECRET=
AWS_ROOT_PATH=
AWS_FORCE_PATH_STYLE=false
# Public media base URL + host (host is added to CSP img-src/media-src).
UPLOAD_CDN_URL=
UPLOAD_CDN_HOST=

# ===========================================
# Backup (production only)
# ===========================================
BACKUP_SCHEDULE_BASE=0 3 * * *
BACKUP_SCHEDULE_DUMP=30 2 * * *
BACKUP_RETENTION_DAYS=7
BACKUP_ON_STARTUP=false
